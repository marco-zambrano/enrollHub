# Gemini API key para el chatbot de EnrollHub
# Obtén tu API key en: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=tu-api-key-de-gemini
VITE_GEMINI_MODEL=gemini-3.5-flash

# Modelo de Gemini (opcional, por defecto gemini-3.5-flash)
# Para usar Gemini 2.5 Flash u otro modelo, cambia esta variable
# VITE_GEMINI_MODEL=gemini-2.5-flash
